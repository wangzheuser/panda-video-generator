# ===========================================
# Copy to .env.local and fill in your values
# ===========================================

# --- /scripts automation wizard ---
# When unset: only available in NODE_ENV=development.
# Set to 1 to enable in production builds; set to 0 to disable even in dev.
# ALLOW_SCRIPTS_WIZARD=1

# --- News / AI (also used by packages/hn-spider) ---
DEEPSEEK_API_KEY=
KIMI_API_KEY=
EDGE_EXECUTABLE_PATH="/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge"
# Edge read-aloud (node-edge-tts): use names like zh-CN-YunjianNeural, not Azure-style zh-CN-Yunjian:Neural
EDGE_TTS_VOICE=zh-CN-YunjianNeural
# Parallel paragraphs per batch (default 3; same as internal max-retries-per-paragraph default)
EDGE_TTS_BATCH_SIZE=3
# Optional: per-paragraph socket timeout ms (library default was 10000; too low for long lines)
# EDGE_TTS_TIMEOUT_MS=120000