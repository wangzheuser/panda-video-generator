# ===========================================
# Copy to .env and fill in your values
# ===========================================

# --- /scripts automation wizard ---
# When unset: only available in NODE_ENV=development.
# Set to 1 to enable in production builds; set to 0 to disable even in dev.
ALLOW_SCRIPTS_WIZARD=1

# --- News / AI (also used by packages/hn-spider) ---
DEEPSEEK_API_KEY=
EDGE_TTS_VOICE=zh-CN-YunjianNeural
EDGE_TTS_BATCH_SIZE=3