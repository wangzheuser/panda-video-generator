{
  "name": "panda-video-generator",
  "version": "1.2.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=8.0.0"
  },
  "author": {
    "name": "szhshp",
    "url": "https://github.com/szhshp"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@panda-video-generator/caption-generator": "workspace:*",
    "@panda-video-generator/spider": "workspace:*",
    "@panda-video-generator/tts-node": "workspace:*",
    "@remotion/bundler": "4.0.409",
    "@remotion/cli": "4.0.409",
    "@remotion/fonts": "4.0.409",
    "@remotion/google-fonts": "4.0.409",
    "@remotion/lambda": "4.0.409",
    "@remotion/media": "4.0.409",
    "@remotion/paths": "4.0.409",
    "@remotion/player": "4.0.409",
    "@remotion/shapes": "4.0.409",
    "@remotion/tailwind-v4": "4.0.409",
    "@vercel/analytics": "^2.0.1",
    "clsx": "2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.409",
    "tailwind-merge": "3.0.1",
    "zod": "3.22.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.1.0",
    "@eslint/js": "9.38.0",
    "@next/eslint-plugin-next": "15.1.6",
    "@playwright/test": "^1.58.0",
    "@remotion/eslint-plugin": "4.0.409",
    "@tailwindcss/postcss": "4.1.1",
    "@types/node": "20.12.14",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/web": "0.0.166",
    "@typescript-eslint/eslint-plugin": "8.46.0",
    "@typescript-eslint/parser": "8.46.0",
    "autoprefixer": "10.4.20",
    "cross-env": "^10.1.0",
    "dotenv": "16.0.3",
    "eslint": "9.19.0",
    "eslint-config-next": "15.1.6",
    "playwright": "1.58.0",
    "postcss": "8.4.47",
    "prettier": "3.6.0",
    "tailwindcss": "4.0.3",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.0"
  },
  "scripts": {
    "dev": "next dev",
    "automation": "node scripts/dev-with-runner.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check:setup": "node scripts/check-setup.mjs",
    "install:project": "node scripts/run-install.mjs",
    "postinstall": "node scripts/playwright-postinstall.mjs",
    "remotion": "remotion studio",
    "render": "remotion render",
    "tts": "cross-env SPIDER_OUTPUT_DIR=output/spider TTS_OUTPUT_DIR=output/tts TTS_PUBLIC_DIR=public/tts node scripts/run-tts.mjs",
    "render:video": "cross-env SPIDER_OUTPUT_DIR=output/spider TTS_OUTPUT_DIR=output/tts TTS_PUBLIC_DIR=public/tts node scripts/run-render-video.mjs",
    "render:composition": "node scripts/run-render-composition.mjs",
    "shuffle:bg-video": "node scripts/shuffle-bg-asset.mjs video",
    "shuffle:bgm": "node scripts/shuffle-bg-asset.mjs bgm",
    "shuffle:all": "node scripts/shuffle-bg-asset.mjs video && node scripts/shuffle-bg-asset.mjs bgm",
    "pipeline:tts-render": "cross-env SPIDER_OUTPUT_DIR=output/spider TTS_OUTPUT_DIR=output/tts TTS_PUBLIC_DIR=public/tts node scripts/run-pipeline-tts-render.mjs",
    "render:all": "pnpm run pipeline:tts-render",
    "remotion:deploy": "node deploy.mjs",
    "spider:zhihu": "cross-env SPIDER_OUTPUT_DIR=output/spider node scripts/run-spider-zhihu.mjs",
    "spider:extract:file": "cross-env SPIDER_OUTPUT_DIR=output/spider tsx packages/spider/cli-extract-text-file-json.ts",
    "spider:extract:url": "cross-env SPIDER_OUTPUT_DIR=output/spider tsx packages/spider/cli-extract-page-url-json.ts",
    "caption:env": "cross-env SPIDER_OUTPUT_DIR=output/spider CAPTION_OUTPUT_DIR=output/spider CAPTION_INPUT_JSON=output/spider/output.json tsx packages/caption-generator/cli-env.ts",
    "sync:public": "cross-env SPIDER_OUTPUT_DIR=output/spider TTS_OUTPUT_DIR=output/tts TTS_PUBLIC_DIR=public/tts SPIDER_PUBLIC_DIR=public/spider VIDEO_PUBLIC_DIR=public/video node scripts/sync-outputs-to-public.mjs",
    "pipeline:zhihu-video": "cross-env SPIDER_OUTPUT_DIR=output/spider node scripts/run-pipeline-zhihu-video.mjs",
    "video:zhihu": "cross-env SPIDER_OUTPUT_DIR=output/spider node scripts/run-pipeline-zhihu-video.mjs",
    "login:bilibili": "playwright test automations/Bilibili/login-bilibili.spec.ts --project=chromium --headed",
    "login:douyin": "playwright test automations/Douyin/login-douyin.spec.ts --project=chromium --headed",
    "login:kuaishou": "playwright test automations/Kuaishou/login-kuaishou.spec.ts --project=chromium --headed",
    "login:rednote": "playwright test automations/RedNote/login-rednote.spec.ts --project=chromium --headed",
    "login:weixin-video": "playwright test automations/WeixinVideo/login-weixin-video.spec.ts --project=chromium --headed",
    "login:youtube": "playwright test automations/YouTube/login-youtube.spec.ts --project=chromium --headed",
    "upload:bilibili": "playwright test automations/Bilibili/upload-video.spec.ts --project=chromium --headed",
    "upload:douyin": "playwright test automations/Douyin/upload-video.spec.ts --project=chromium --headed",
    "upload:kuaishou": "playwright test automations/Kuaishou/upload-video.spec.ts --project=chromium --headed",
    "upload:rednote": "playwright test automations/RedNote/upload-video.spec.ts --project=chromium --headed",
    "upload:weixin-video": "playwright test automations/WeixinVideo/upload-weixin-video.spec.ts --project=chromium --headed",
    "upload:youtube": "playwright test automations/YouTube/upload-video.spec.ts --project=chromium --headed",
    "upload:all": "playwright test automations/Bilibili/upload-video.spec.ts automations/Douyin/upload-video.spec.ts automations/YouTube/upload-video.spec.ts automations/RedNote/upload-video.spec.ts automations/Kuaishou/upload-video.spec.ts automations/WeixinVideo/upload-weixin-video.spec.ts --project=chromium --headed"
  }
}