import { test } from '@playwright/test';
import { performLogin, getAuthFilePath } from '../utils/login-helper';

/**
 * Login script template for [Platform Name]
 * 
 * Copy this file to your platform folder and customize:
 * 1. Replace [Platform Name] with actual platform name
 * 2. Update loginUrl with the platform's login URL
 * 3. Update loginIndicators with selectors that indicate logged-in state
 * 4. Update authFilePath platform name (should match folder name)
 * 
 * Usage: playwright test automations/[Platform]/login-[platform].spec.ts --project=chromium --headed
 * 
 * Note: This script has NO timeout limit - you can take as long as you need to login.
 * The script will pause and wait for you to complete the login process manually.
 */

// Disable timeout for login tests - allow infinite wait for user input
test.describe.configure({ timeout: 0 });

test('login to [platform] - run this once to save login state', async ({ page, context }) => {
  // Set timeout to 0 (infinite) for this specific test
  test.setTimeout(0);
  
  await performLogin(page, context, {
    platform: '[Platform Name]',
    loginUrl: 'https://example.com/login',
    loginIndicators: [
      // Add selectors that indicate logged-in state
      // Examples:
      // '.user-avatar',
      // '[data-testid="user-menu"]',
      // 'text=Profile',
    ],
    authFilePath: getAuthFilePath('[platform]'),
  });
});
